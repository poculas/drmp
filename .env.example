# Django Configuration
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Database Configuration
# For Render, DATABASE_URL is automatically set by Render
# For local development, leave DATABASE_URL empty to use SQLite
DATABASE_URL=

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# PayMongo Payment Gateway Configuration
PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_API_URL=https://api.paymongo.com/v1
BASE_URL=http://127.0.0.1:8000

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@je-cole-bakery.com

# Cache Configuration (Optional - Redis URL for production)
REDIS_URL=

# Logging Configuration (Optional - Custom logs directory)
LOGS_DIR=

# Security Configuration (Optional)
SECURE_SSL_REDIRECT=True

# Static Files Configuration (Optional - for Render deployment)
STATIC_URL=/static/
STATIC_ROOT=

# Media Configuration (Optional - for cloud storage on Render)
MEDIA_URL=/media/
MEDIA_ROOT=

# Render-specific Configuration (Automatically set by Render)
# RENDER=true
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
